# =============================================
# 袋享印 · 环境变量配置
# 复制本文件为 .env 并填写真实值
# =============================================

# 服务端口
PORT=3000
NODE_ENV=development

# JWT 密钥（生产环境务必修改）
JWT_SECRET=your-super-secret-key-change-in-production

# 允许的跨域源（逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-h5-domain.com

# API 基础地址（回调通知用）
API_BASE=https://your-api-domain.com

# =============================================
# PostgreSQL 数据库
# =============================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=daixiangyin
PG_USER=postgres
PG_PASSWORD=your-postgres-password

# =============================================
# 腾讯云 COS（文件存储）
# =============================================
COS_SECRET_ID=your-tencent-cloud-secret-id
COS_SECRET_KEY=your-tencent-cloud-secret-key
COS_BUCKET=daixiangyin-assets
COS_REGION=ap-guangzhou
COS_CDN_BASE=https://your-cdn-domain.com

# =============================================
# 微信小程序
# =============================================
WX_APPID=wx0000000000000000
WX_SECRET=your-wechat-app-secret

# =============================================
# 微信支付（V3 API）
# =============================================
WX_MCHID=your-merchant-id
WX_SERIAL=your-merchant-serial-number
WX_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
WX_APIV3_KEY=your-apiv3-key
