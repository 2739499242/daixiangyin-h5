/* components/tabbar/index.wxss */

.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid #EEEEEE;
}

.tabbar__safe {
  width: 100%;
}

.tabbar__inner {
  display: flex;
  align-items: center;
  height: 56px;
}

.tabbar__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  height: 100%;
  transition: all 150ms ease-out;
}

.tabbar__icon {
  width: 24px;
  height: 24px;
}

.tabbar__label {
  font-size: 11px;
  font-weight: 500;
  color: #9E9E9E;
  letter-spacing: 0.02em;
  transition: color 150ms ease-out;
}

.tabbar__item--active .tabbar__label {
  color: #1A2B23;
}
