/* =========================================
   袋享印 · 全局样式变量
   现代简约专业风格 · v2.0
   ========================================= */

/* 品牌色 */
page {
  --color-primary: #1A2B23;
  --color-primary-light: #2D4A3C;
  --color-primary-pale: #E8EFEA;
  --color-accent: #C9A76C;
  --color-accent-light: #D4BC8F;
  --color-accent-pale: #F7F3EB;

  /* 中性色 */
  --color-white: #FFFFFF;
  --color-gray-50: #FAFAFA;
  --color-gray-100: #F5F5F5;
  --color-gray-200: #EEEEEE;
  --color-gray-300: #E0E0E0;
  --color-gray-400: #BDBDBD;
  --color-gray-500: #9E9E9E;
  --color-gray-600: #757575;
  --color-gray-700: #616161;
  --color-gray-800: #424242;
  --color-gray-900: #212121;

  /* 功能色 */
  --color-success: #34A853;
  --color-warning: #F9AB00;
  --color-error: #EA4335;
  --color-info: #4285F4;

  /* 字体 */
  --font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Noto Sans SC", sans-serif;
  --font-serif: "Noto Serif SC", "Songti SC", Georgia, serif;

  /* 间距 */
  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;
  --space-10: 40px;

  /* 圆角 */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-full: 9999px;

  /* 阴影 */
  --shadow-sm: 0 2px 4px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.08), 0 2px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 8px 24px rgba(0,0,0,0.10), 0 4px 8px rgba(0,0,0,0.06);
  --shadow-accent: 0 0 20px rgba(201,167,108,0.3);

  /* 页面 */
  --page-padding-x: 20px;
  --page-safe-top: env(safe-area-inset-top);
  --page-safe-bottom: env(safe-area-inset-bottom);

  background-color: var(--color-gray-50);
  font-family: var(--font-family);
  font-size: 15px;
  color: var(--color-gray-800);
  line-height: 1.6;
}

/* 重置 */
view, text, navigator, button, image, input, textarea {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* 通用工具类 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { justify-content: center; align-items: center; }
.flex-between { justify-content: space-between; align-items: center; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.gap-2 { gap: var(--space-2); }
.gap-3 { gap: var(--space-3); }
.gap-4 { gap: var(--space-4); }
.gap-6 { gap: var(--space-6); }

.mt-2 { margin-top: var(--space-2); }
.mt-3 { margin-top: var(--space-3); }
.mt-4 { margin-top: var(--space-4); }
.mt-6 { margin-top: var(--space-6); }
.mb-4 { margin-bottom: var(--space-4); }
.mb-6 { margin-bottom: var(--space-6); }
.px-4 { padding-left: var(--space-4); padding-right: var(--space-4); }
.py-4 { padding-top: var(--space-4); padding-bottom: var(--space-4); }

.text-primary { color: var(--color-primary); }
.text-accent { color: var(--color-accent); }
.text-secondary { color: var(--color-gray-600); }
.text-sm { font-size: 13px; }
.text-xs { font-size: 11px; }
.text-lg { font-size: 18px; }
.text-xl { font-size: 22px; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 按钮 */
.btn {
  height: 44px;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 500;
  letter-spacing: 0.02em;
  border: none;
  transition: all 150ms ease-out;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--color-white);
}

.btn-primary:active {
  background: var(--color-primary-light);
  transform: translateY(1px);
}

.btn-accent {
  background: linear-gradient(135deg, #C9A76C 0%, #D4BC8F 100%);
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: var(--shadow-accent);
}

.btn-accent:active {
  transform: translateY(1px);
  opacity: 0.9;
}

.btn-secondary {
  background: var(--color-gray-100);
  color: var(--color-gray-900);
  border: 1px solid var(--color-gray-200);
}

.btn-secondary:active {
  background: var(--color-gray-200);
}

.btn-ghost {
  background: transparent;
  color: var(--color-gray-600);
}

.btn-ghost:active {
  color: var(--color-primary);
  background: var(--color-gray-100);
}

/* 卡片 */
.card {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  border: 1px solid var(--color-gray-200);
  padding: var(--space-6);
  box-shadow: var(--shadow-sm);
  transition: all 200ms ease-out;
}

/* 输入框 */
.input {
  height: 44px;
  padding: 0 16px;
  background: var(--color-white);
  border: 1px solid var(--color-gray-200);
  border-radius: var(--radius-md);
  font-size: 15px;
  color: var(--color-gray-900);
  width: 100%;
  transition: all 150ms ease-out;
}

.input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(26,43,35,0.08);
  outline: none;
}

.input::placeholder {
  color: var(--color-gray-400);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  height: 28px;
  padding: 0 12px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  font-weight: 500;
}

.tag-primary {
  background: var(--color-primary);
  color: var(--color-white);
}

.tag-outline {
  background: transparent;
  border: 1px solid var(--color-gray-300);
  color: var(--color-gray-600);
}

/* 分隔线 */
.divider {
  height: 1px;
  background: var(--color-gray-200);
  width: 100%;
}

/* 骨架屏 */
.skeleton {
  background: linear-gradient(90deg, var(--color-gray-100) 25%, var(--color-gray-200) 50%, var(--color-gray-100) 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: var(--radius-md);
}

@keyframes skeleton-pulse {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 40px;
  gap: var(--space-4);
}

.empty-state__icon {
  width: 80px;
  height: 80px;
  opacity: 0.4;
}

.empty-state__text {
  font-size: 14px;
  color: var(--color-gray-500);
  text-align: center;
}
