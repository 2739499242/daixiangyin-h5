/* pages/order/index.wxss */

.page-order {
  min-height: 100vh;
  background: var(--color-gray-50);
}

/* 导航 */
.order-nav {
  height: 56px;
  padding: 0 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: white;
  border-bottom: 1px solid var(--color-gray-200);
}

.order-nav__back {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: var(--color-gray-800);
}

.order-nav__title {
  font-size: 16px;
  font-weight: 600;
  color: var(--color-gray-900);
}

/* Tab */
.order-tabs {
  display: flex;
  background: white;
  padding: 0 var(--page-padding-x);
  border-bottom: 1px solid var(--color-gray-200);
  position: sticky;
  top: 56px;
  z-index: 10;
}

.order-tab {
  flex: 1;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: var(--color-gray-500);
  font-weight: 500;
  position: relative;
  transition: color 150ms ease-out;
}

.order-tab--active {
  color: var(--color-primary);
}

.order-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 24px;
  height: 2px;
  background: var(--color-primary);
  border-radius: 1px;
}

/* 订单列表 */
.order-list {
  padding: 16px var(--page-padding-x) 100px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 订单卡片 */
.order-card {
  background: white;
  border-radius: var(--radius-lg);
  padding: 16px;
  border: 1px solid var(--color-gray-200);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.order-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-card__no {
  font-size: 12px;
  color: var(--color-gray-500);
  font-family: monospace;
}

.order-card__status {
  font-size: 12px;
  font-weight: 600;
  padding: 2px 10px;
  border-radius: var(--radius-full);
}

.status--paid,
.status--producing { background: var(--color-accent-pale); color: var(--color-accent); }
.status--shipped { background: var(--color-info-light); color: var(--color-info); }
.status--delivered { background: var(--color-success-light); color: var(--color-success); }
.status--pending { background: var(--color-warning-light); color: var(--color-warning); }

/* 产品 */
.order-card__product {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.order-card__img {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-md);
  background: var(--color-gray-100);
  flex-shrink: 0;
}

.order-card__info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.order-card__name {
  font-size: 14px;
  font-weight: 600;
  color: var(--color-gray-800);
}

.order-card__specs {
  font-size: 12px;
  color: var(--color-gray-500);
}

.order-card__meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 4px;
}

.order-card__qty {
  font-size: 12px;
  color: var(--color-gray-500);
}

.order-card__price {
  font-size: 15px;
  font-weight: 700;
  color: var(--color-primary);
}

/* 时间轴 */
.order-card__timeline {
  display: flex;
  align-items: flex-start;
  gap: 0;
  padding: 12px 0 4px;
  position: relative;
}

.order-card__timeline::before {
  content: '';
  position: absolute;
  top: 18px;
  left: 4px;
  right: 4px;
  height: 2px;
  background: var(--color-gray-200);
}

.timeline-step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  position: relative;
  z-index: 1;
}

.timeline-step__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--color-gray-300);
  transition: all 200ms ease-out;
}

.timeline-step--done .timeline-step__dot {
  background: var(--color-success);
}

.timeline-step--current .timeline-step__dot {
  background: var(--color-accent);
  box-shadow: 0 0 0 3px var(--color-accent-pale);
}

.timeline-step__label {
  font-size: 10px;
  color: var(--color-gray-400);
  text-align: center;
}

.timeline-step--done .timeline-step__label,
.timeline-step--current .timeline-step__label {
  color: var(--color-gray-700);
}

/* 操作 */
.order-card__actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding-top: 8px;
  border-top: 1px solid var(--color-gray-100);
}

.btn-sm {
  height: 32px;
  padding: 0 16px;
  font-size: 13px;
}
