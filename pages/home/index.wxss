/* pages/home/index.wxss */

/* 页面容器 */
.page-home {
  min-height: 100vh;
  background: var(--color-gray-50);
}

/* ========================
   导航栏
   ======================== */
.nav-bar {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-bar__inner {
  height: 56px;
  padding: 0 var(--page-padding-x);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-bar__logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.nav-bar__brand {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-gray-900);
  letter-spacing: -0.01em;
}

.nav-bar__divider {
  width: 1px;
  height: 16px;
  background: var(--color-gray-300);
}

.nav-bar__tagline {
  font-size: 12px;
  color: var(--color-gray-500);
  font-weight: 400;
}

.nav-bar__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.nav-bar__search-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-gray-100);
  border-radius: var(--radius-md);
}

.nav-bar__icon {
  width: 18px;
  height: 18px;
}

.nav-bar__avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid var(--color-gray-200);
}

/* ========================
   Hero 区域
   ======================== */
.hero {
  background: linear-gradient(180deg, #FFFFFF 0%, #F0F5F2 100%);
  padding: 20px var(--page-padding-x) 24px;
  display: flex;
  align-items: center;
  gap: 16px;
  position: relative;
  overflow: hidden;
}

.hero::after {
  content: '';
  position: absolute;
  bottom: -40px;
  right: -40px;
  width: 200px;
  height: 200px;
  border-radius: 50%;
  background: rgba(201, 167, 108, 0.08);
}

.hero__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 1;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  height: 22px;
  padding: 0 8px;
  background: var(--color-accent-pale);
  color: var(--color-accent);
  font-size: 11px;
  font-weight: 700;
  border-radius: var(--radius-full);
  width: fit-content;
}

.hero__title {
  font-size: 24px;
  font-weight: 700;
  color: var(--color-gray-900);
  line-height: 1.3;
  letter-spacing: -0.02em;
}

.hero__subtitle {
  font-size: 13px;
  color: var(--color-gray-500);
  margin-bottom: 4px;
}

.hero__cta {
  width: fit-content;
  margin-top: 4px;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.hero__cta-arrow {
  font-size: 16px;
  transition: transform 150ms ease-out;
}

.hero__cta:active .hero__cta-arrow {
  transform: translateX(4px);
}

.hero__stats {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: 4px;
}

.hero__stat {
  display: flex;
  flex-direction: column;
}

.hero__stat-num {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-primary);
}

.hero__stat-label {
  font-size: 11px;
  color: var(--color-gray-500);
}

.hero__stat-divider {
  width: 1px;
  height: 24px;
  background: var(--color-gray-200);
}

.hero__visual {
  width: 160px;
  height: 200px;
  position: relative;
  flex-shrink: 0;
}

.hero__bag {
  width: 100%;
  height: 100%;
  background: var(--color-primary-pale);
  border-radius: var(--radius-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
}

.hero__bag-img {
  width: 120px;
  height: 150px;
  opacity: 0.8;
}

.hero__floating {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 4px;
  background: white;
  padding: 6px 10px;
  border-radius: var(--radius-full);
  box-shadow: var(--shadow-md);
  font-size: 12px;
  color: var(--color-gray-800);
}

.hero__floating--1 {
  top: 10px;
  right: -10px;
  animation: float 3s ease-in-out infinite;
}

.hero__floating--2 {
  bottom: 30px;
  left: -10px;
  animation: float 3s ease-in-out infinite 1.5s;
}

.hero__floating-text {
  font-size: 11px;
  font-weight: 500;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

/* ========================
   通用区块
   ======================== */
.section {
  padding: 20px var(--page-padding-x);
}

.section__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.section__title {
  font-size: 18px;
  font-weight: 600;
  color: var(--color-gray-900);
}

.section__more {
  font-size: 13px;
  color: var(--color-gray-500);
}

/* ========================
   Banner
   ======================== */
.banner {
  background: linear-gradient(135deg, #1A2B23 0%, #2D4A3C 100%);
  border-radius: var(--radius-xl);
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
  position: relative;
}

.banner::after {
  content: '';
  position: absolute;
  top: -30px;
  right: -30px;
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: rgba(201, 167, 108, 0.15);
}

.banner__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  z-index: 1;
}

.banner__title {
  font-size: 16px;
  font-weight: 600;
  color: white;
}

.banner__subtitle {
  font-size: 12px;
  color: rgba(255,255,255,0.7);
}

.banner__tag {
  display: inline-flex;
  height: 20px;
  padding: 0 8px;
  background: var(--color-accent);
  color: var(--color-primary);
  font-size: 10px;
  font-weight: 600;
  border-radius: var(--radius-full);
  align-items: center;
  margin-top: 6px;
  width: fit-content;
}

.banner__cta {
  height: 36px;
  padding: 0 16px;
  background: rgba(255,255,255,0.2);
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  font-size: 13px;
  color: white;
  font-weight: 500;
  z-index: 1;
  border: 1px solid rgba(255,255,255,0.3);
}

/* ========================
   分类卡片
   ======================== */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}

.category-card {
  background: white;
  border-radius: var(--radius-lg);
  padding: 16px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  border: 1px solid var(--color-gray-200);
  transition: all 150ms ease-out;
}

.category-card:active {
  transform: scale(0.97);
  background: var(--color-gray-50);
}

.category-card__icon {
  font-size: 28px;
  line-height: 1;
  margin-bottom: 4px;
}

.category-card__name {
  font-size: 13px;
  font-weight: 600;
  color: var(--color-gray-800);
}

.category-card__count {
  font-size: 11px;
  color: var(--color-gray-500);
}

/* ========================
   案例滚动卡片
   ======================== */
.cases-scroll {
  white-space: nowrap;
  margin: 0 -20px;
  padding: 0 20px;
}

.case-card {
  display: inline-flex;
  flex-direction: column;
  width: 150px;
  margin-right: 12px;
  background: white;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--color-gray-200);
  flex-shrink: 0;
  position: relative;
  transition: transform 150ms ease-out;
}

.case-card:active {
  transform: scale(0.97);
}

.case-card__img {
  width: 150px;
  height: 180px;
}

.case-card__info {
  padding: 10px 12px 8px;
}

.case-card__name {
  font-size: 13px;
  font-weight: 500;
  color: var(--color-gray-800);
  display: block;
}

.case-card__author {
  font-size: 11px;
  color: var(--color-gray-500);
  margin-top: 2px;
}

.case-card__like {
  position: absolute;
  top: 8px;
  right: 8px;
  background: rgba(255,255,255,0.9);
  border-radius: var(--radius-full);
  padding: 3px 8px;
  font-size: 11px;
  color: var(--color-error);
  display: flex;
  align-items: center;
  gap: 2px;
}

/* ========================
   热门设计网格
   ======================== */
.hot-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.hot-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  position: relative;
  aspect-ratio: 1;
  background: var(--color-gray-100);
  transition: transform 150ms ease-out;
}

.hot-card:active {
  transform: scale(0.97);
}

.hot-card__img {
  width: 100%;
  height: 100%;
}

.hot-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 10px 12px;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.hot-card__title {
  font-size: 13px;
  font-weight: 500;
  color: white;
  display: block;
}

.hot-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 12px;
  color: rgba(255,255,255,0.85);
}

.hot-card__use {
  display: flex;
  align-items: center;
  gap: 2px;
}
