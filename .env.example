# 环境变量示例
# 复制此文件为 .env.local 并填写实际值

# API配置
VITE_API_BASE_URL=https://api.daixiangyin.com
VITE_API_TIMEOUT=10000

# 微信小程序配置
VITE_WECHAT_APP_ID=your_wechat_app_id

# 第三方服务
VITE_TENCENT_CLOUD_SECRET_ID=your_secret_id
VITE_TENCENT_CLOUD_SECRET_KEY=your_secret_key
VITE_TENCENT_CLOUD_REGION=ap-guangzhou

# AI服务
VITE_AI_SERVICE=tencent
VITE_AI_MODEL=gpt-4o

# 功能开关
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORT=true
